# --- Gradle ---
# Build output directory (compiled .class files, JARs, test reports)
build/
# Gradle's local cache (downloaded dependencies, daemon state)
.gradle/

# --- IntelliJ IDEA ---
# Per-user IDE settings; not useful to share
.idea/
# Module files (regenerated by IntelliJ on import)
*.iml
# IntelliJ's build output (rarely used with Gradle projects, but harmless)
out/

# --- Kotlin / JVM ---
# Loose compiled classes (shouldn't appear with Gradle, but just in case)
*.class

# --- macOS ---
# Finder metadata files that appear everywhere
.DS_Store